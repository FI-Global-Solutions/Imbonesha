# Copy this file to .env and fill in real values for your environment.
# docker-compose reads from .env automatically (infra/docker-compose.yml).

# ── Notifications ────────────────────────────────────────────────────────────
# 'console' prints to worker logs (safe for development and CI).
# 'sendgrid' sends real emails via SendGrid — requires SENDGRID_API_KEY.
NOTIFICATION_BACKEND=console

# SendGrid API key — get from https://app.sendgrid.com/settings/api_keys
# Only required when NOTIFICATION_BACKEND=sendgrid
SENDGRID_API_KEY=SG.xxxxxx

# Must be a verified sender identity in your SendGrid account
NOTIFICATION_FROM_EMAIL=notifications@imbonesha.gov.rw

# Base URL of the web dashboard — used to build links in email bodies
FRONTEND_URL=http://localhost:3000

# ── Optional overrides ────────────────────────────────────────────────────────
# These have working defaults in docker-compose.yml; only set them here
# if you need to override for local development.

# PERMIT_SERVICE_URL=http://localhost:8015
# ML_SERVICE_URL=http://localhost:8002
# MINIO_ENDPOINT=localhost:9007
